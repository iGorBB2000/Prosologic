<UserControl x:Class="Prosologic.Studio.Views.ProjectPropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <DockPanel Background="{StaticResource BgSurfaceBrush}">

        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgCanvasBrush}"
                BorderBrush="{StaticResource GridLineBrush}"
                BorderThickness="0,0,0,1" Padding="16,6">
            <TextBlock Text="PROJECT CONFIG" Style="{StaticResource PanelIdStyle}"/>
        </Border>

        <TextBlock DockPanel.Dock="Top"
                   Style="{StaticResource EmptyStateStyle}"
                   Text="— no project open —"
                   Margin="0,80,0,0"
                   Visibility="{Binding IsProjectLoaded, Converter={StaticResource InverseBoolToVis}}"/>

        <ScrollViewer Visibility="{Binding IsProjectLoaded, Converter={StaticResource BoolToVis}}">
            <StackPanel>

                <!-- Project name hero -->
                <Border Background="{StaticResource BgCanvasBrush}"
                        BorderBrush="{StaticResource GridLineBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="PROJECT NAME"
                                   FontFamily="{StaticResource LabelFont}"
                                   FontSize="{StaticResource FontSizeXxs}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource HeroInputStyle}" Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- METADATA register block -->
                <StackPanel Margin="16,14,16,0">
                    <Border Style="{StaticResource BlockHeaderStyle}">
                        <TextBlock Text="METADATA" Style="{StaticResource BlockTitleStyle}"/>
                    </Border>
                    <Border Style="{StaticResource RegisterBlockStyle}">
                        <StackPanel>
                            <Grid Height="34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Version"
                                           Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                         Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="10,0,10,0"/>
                            </Grid>
                            <Border Style="{StaticResource HairlineStyle}"/>
                            <Grid Height="34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Author"
                                           Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                         Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="10,0,10,0"/>
                            </Grid>
                            <Border Style="{StaticResource HairlineStyle}"/>
                            <Grid MinHeight="34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Description"
                                           Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                <TextBox Grid.Column="2" Style="{StaticResource DarkTextBoxStyle}"
                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="56" BorderThickness="0" Margin="0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- PROTOCOL register block -->
                <StackPanel Margin="16,14,16,0">
                    <Border Style="{StaticResource BlockHeaderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PROTOCOL" Style="{StaticResource BlockTitleStyle}"/>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBoxStyle}"
                                      ItemsSource="{Binding AvailableProtocols}"
                                      SelectedItem="{Binding SelectedProtocol}"
                                      BorderThickness="0" Padding="6,2"
                                      Background="Transparent"/>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource RegisterBlockStyle}">
                        <StackPanel>

                            <!-- MQTT -->
                            <StackPanel Visibility="{Binding IsMqtt, Converter={StaticResource BoolToVis}}">
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Broker"
                                               Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                    <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                             Text="{Binding MqttBrokerAddress, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="10,0,10,0"/>
                                </Grid>
                                <Border Style="{StaticResource HairlineStyle}"/>
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Port"
                                               Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                    <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                             Text="{Binding MqttPort, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="10,0,10,0"/>
                                </Grid>
                                <Border Style="{StaticResource HairlineStyle}"/>
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Client ID"
                                               Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                    <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                             Text="{Binding MqttClientId, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="10,0,10,0"/>
                                </Grid>
                                <Border Style="{StaticResource HairlineStyle}"/>
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Topic Prefix"
                                               Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                    <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                             Text="{Binding MqttTopicPrefix, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="10,0,10,0"/>
                                </Grid>
                            </StackPanel>

                            <!-- OPC UA -->
                            <StackPanel Visibility="{Binding IsOpcUa, Converter={StaticResource BoolToVis}}">
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Server Name"
                                               Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                    <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                             Text="{Binding OpcUaServerName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="10,0,10,0"/>
                                </Grid>
                                <Border Style="{StaticResource HairlineStyle}"/>
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Port"
                                               Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                    <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                             Text="{Binding OpcUaPort, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="10,0,10,0"/>
                                </Grid>
                                <Border Style="{StaticResource HairlineStyle}"/>
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="App URI"
                                               Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                    <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                             Text="{Binding OpcUaApplicationUri, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="10,0,10,0"/>
                                </Grid>
                                <Border Style="{StaticResource HairlineStyle}"/>
                                <Grid Height="34">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Namespace URI"
                                               Style="{StaticResource RegisterKeyStyle}" Margin="10,0,0,0"/>
                                    <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                    <TextBox Grid.Column="2" Style="{StaticResource RegisterInputStyle}"
                                             Text="{Binding OpcUaNamespaceUri, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="10,0,10,0"/>
                                </Grid>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Action bar -->
                <Border Margin="16,14,16,20"
                        Background="{StaticResource BgCanvasBrush}"
                        BorderBrush="{StaticResource GridLineBrush}"
                        BorderThickness="1" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="SAVE"
                                   Command="{Binding SaveCommand}" Appearance="Primary"/>
                        <ui:Button Grid.Column="2" Content="RESET" Command="{Binding ResetCommand}"/>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="4" Height="4"
                                     Fill="{StaticResource WarningBrush}" Margin="0,0,5,0"/>
                            <TextBlock Text="unsaved changes"
                                       FontFamily="{StaticResource LabelFont}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
