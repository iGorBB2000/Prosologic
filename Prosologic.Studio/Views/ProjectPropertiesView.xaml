<UserControl x:Class="Prosologic.Studio.Views.ProjectPropertiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Prosologic.Studio.ViewModels">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="#2D2D30"
                Padding="12,8"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1">
            <TextBlock Text="PROJECT PROPERTIES"
                       Foreground="#CCCCCC"
                       FontWeight="SemiBold"
                       FontSize="12"/>
        </Border>

        <!-- Content -->
        <ScrollViewer>
            <StackPanel Margin="20">

                <!-- Not loaded -->
                <TextBlock Text="No project open"
                           Foreground="#808080"
                           FontStyle="Italic"
                           Margin="0,0,0,12"
                           Visibility="{Binding IsProjectLoaded, Converter={StaticResource InverseBoolToVis}}"/>

                <!-- Loaded -->
                <StackPanel Visibility="{Binding IsProjectLoaded, Converter={StaticResource BoolToVis}}">
                    <StackPanel.Resources>
                        <Style TargetType="StackPanel">
                            <Setter Property="Margin" Value="0,0,0,8"/>
                        </Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                        </Style>
                    </StackPanel.Resources>

                    <!-- ── General ── -->
                    <TextBlock Text="General"
                               Foreground="#FFFFFF"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,0,0,12"/>

                    <StackPanel>
                        <TextBlock Text="Project Name"/>
                        <ui:TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Project name"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Version"/>
                        <ui:TextBox Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="1.0.0"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Author"/>
                        <ui:TextBox Text="{Binding Author, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Your name"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Description"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="60"/>
                    </StackPanel>

                    <!-- ── Protocol ── -->
                    <Separator Background="#3E3E42" Margin="0,8"/>

                    <TextBlock Text="Protocol"
                               Foreground="#FFFFFF"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,0,0,12"/>

                    <StackPanel>
                        <TextBlock Text="Protocol Type"/>
                        <ComboBox ItemsSource="{Binding AvailableProtocols}"
                                  SelectedItem="{Binding SelectedProtocol}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- MQTT Settings -->
                    <StackPanel Visibility="{Binding IsMqtt, Converter={StaticResource BoolToVis}}">

                        <TextBlock Text="MQTT Client Settings"
                                   Foreground="#00BFFF"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,8"/>

                        <StackPanel>
                            <TextBlock Text="Broker Address"/>
                            <ui:TextBox Text="{Binding MqttBrokerAddress, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="localhost or mqtt.example.com"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Port"/>
                            <ui:TextBox Text="{Binding MqttPort, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="1883"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Client ID"/>
                            <ui:TextBox Text="{Binding MqttClientId, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="prosologic-plc"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Topic Prefix"/>
                            <ui:TextBox Text="{Binding MqttTopicPrefix, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="factory/line1"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- OPC UA Settings -->
                    <StackPanel Visibility="{Binding IsOpcUa, Converter={StaticResource BoolToVis}}">

                        <TextBlock Text="OPC UA Server Settings"
                                   Foreground="#90EE90"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,8"/>

                        <StackPanel>
                            <TextBlock Text="Server Name"/>
                            <ui:TextBox Text="{Binding OpcUaServerName, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="Prosologic PLC"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Port"/>
                            <ui:TextBox Text="{Binding OpcUaPort, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="4840"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Application URI"/>
                            <ui:TextBox Text="{Binding OpcUaApplicationUri, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="urn:prosologic:plc"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Namespace URI"/>
                            <ui:TextBox Text="{Binding OpcUaNamespaceUri, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="http://prosologic.com/plc"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <ui:Button Content="Save Changes"
                                   Command="{Binding SaveCommand}"
                                   Appearance="Primary"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Reset"
                                   Command="{Binding ResetCommand}"/>
                    </StackPanel>

                    <!-- Unsaved indicator -->
                    <TextBlock Text="● Unsaved changes"
                               Foreground="#FFA500"
                               FontSize="11"
                               Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}}"/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>
