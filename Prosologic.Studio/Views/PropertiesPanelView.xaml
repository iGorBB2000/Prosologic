<UserControl x:Class="Prosologic.Studio.Views.PropertiesPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Prosologic.Studio.Views"
             x:Name="Root">

    <Grid>
        <!-- Empty state -->
        <TextBlock Style="{StaticResource EmptyStateStyle}"
                   Text="Select an item to inspect its properties"
                   Visibility="{Binding ShowNone, Converter={StaticResource BoolToVis}}"/>

        <views:ProjectPropertiesView DataContext="{Binding ProjectProperties}"
            Visibility="{Binding DataContext.ShowProjectProperties, ElementName=Root, Converter={StaticResource BoolToVis}}"/>

        <views:TagGroupEditorView DataContext="{Binding TagGroupEditor}"
            Visibility="{Binding DataContext.ShowTagGroupEditor, ElementName=Root, Converter={StaticResource BoolToVis}}"/>

        <views:TagEditorView DataContext="{Binding TagEditor}"
            Visibility="{Binding DataContext.ShowTagEditor, ElementName=Root, Converter={StaticResource BoolToVis}}"/>
    </Grid>
</UserControl>
