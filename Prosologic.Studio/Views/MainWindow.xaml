<ui:FluentWindow x:Class="Prosologic.Studio.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Prosologic.Studio.ViewModels"
        xmlns:views="clr-namespace:Prosologic.Studio.Views"
        Title="{Binding WindowTitle}"
        Width="1200" Height="800"
        Background="#1E1E1E"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <DockPanel>

        <!-- Title Bar -->
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="{Binding WindowTitle}"
                     Background="#2D2D30">
        </ui:TitleBar>

        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="#2D2D30">
            <MenuItem Header="_File" Foreground="White">
                <MenuItem Header="_New Project"
                          Command="{Binding NewProjectCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="_Open Project"
                          Command="{Binding OpenProjectCommand}"
                          InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save"
                          Command="{Binding SaveProjectCommand}"
                          InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="Save _As..."
                          Command="{Binding SaveAsProjectCommand}"
                          InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="_Close Project"
                          Command="{Binding CloseProjectCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit"
                          Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit" Foreground="White">
                <MenuItem Header="Add Tag Group"
                          IsEnabled="{Binding IsProjectOpen}"
                          Command="{Binding ProjectExplorer.AddTagGroupCommand}"
                          InputGestureText="Ctrl+Shift+G"/>
                <MenuItem Header="Add Tag"
                          IsEnabled="{Binding IsProjectOpen}"
                          Command="{Binding ProjectExplorer.AddTagCommand}"
                          InputGestureText="Ctrl+Shift+T"/>
                <Separator/>
                <MenuItem Header="Delete"
                          IsEnabled="False"
                          Command="{Binding ProjectExplorer.DeleteCommand}"
                          InputGestureText="Delete"/>
            </MenuItem>
            <MenuItem Header="_View" Foreground="White">
                <MenuItem Header="{Binding ShowContainersPanelText}"
                          Command="{Binding ToggleContainersCommand}"/>
            </MenuItem>
            <MenuItem Header="_Deploy" Foreground="White">
                <MenuItem Header="Deploy to Container"
                          IsEnabled="{Binding IsProjectOpen}"/>
                <MenuItem Header="Stop All Containers"/>
            </MenuItem>
            <MenuItem Header="_Help" Foreground="White">
                <MenuItem Header="Documentation"/>
                <MenuItem Header="About"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#007ACC"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="White"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding CurrentProject.ProjectName, TargetNullValue='No project open'}"
                           Foreground="White"
                           FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Main 2-Panel Layout -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="160"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Project Explorer -->
                <Border Grid.Column="0"
                        Background="#252526"
                        BorderBrush="#3E3E42"
                        BorderThickness="0,0,1,0">
                    <views:ProjectExplorerView DataContext="{Binding ProjectExplorer}"/>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              Background="#3E3E42"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>

                <!-- Right: Properties Panel -->
                <Border Grid.Column="2" Background="#1E1E1E">
                    <views:PropertiesPanelView DataContext="{Binding PropertiesPanel}"/>
                </Border>
            </Grid>

            <!-- Splitter for bottom panel -->
            <GridSplitter Grid.Row="1"
                          Height="4"
                          Background="#3E3E42"
                          HorizontalAlignment="Stretch"
                          Visibility="{Binding ShowContainersPanel, Converter={StaticResource BoolToVis}}"/>

            <!-- Bottom: Containers Panel -->
            <Border Grid.Row="2"
                    Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="0,1,0,0"
                    Height="200"
                    Visibility="{Binding ShowContainersPanel, Converter={StaticResource BoolToVis}}">
                <views:ContainerManagerView/>
            </Border>

        </Grid>

    </DockPanel>

</ui:FluentWindow>
