<UserControl x:Class="Prosologic.Studio.Views.ContainerManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="80">
    <DockPanel Background="{StaticResource BgCanvasBrush}">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgCanvasBrush}"
                BorderBrush="{StaticResource GridLineBrush}"
                BorderThickness="0,0,0,1" Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="CONTAINERS" Style="{StaticResource PanelIdStyle}"/>
                <!-- Live indicator: no containers = no green dot -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="IDLE"
                               FontFamily="{StaticResource LabelFont}"
                               FontSize="{StaticResource FontSizeXxs}"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Grid>
        </Border>
        <TextBlock Style="{StaticResource EmptyStateStyle}"
                   Text="no containers deployed"/>
    </DockPanel>
</UserControl>
