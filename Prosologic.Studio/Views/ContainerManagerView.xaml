<UserControl x:Class="Prosologic.Studio.Views.ContainerManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="#2D2D30"
                Padding="12,8"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="CONTAINERS"
                           Foreground="#CCCCCC"
                           FontWeight="SemiBold"
                           FontSize="12"/>
                <TextBlock Grid.Column="2"
                           Text="Hide"
                           Foreground="#007ACC"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Border Padding="12">
            <TextBlock Text="No containers deployed yet"
                       Foreground="#808080"
                       FontStyle="Italic"/>
        </Border>

    </DockPanel>

</UserControl>