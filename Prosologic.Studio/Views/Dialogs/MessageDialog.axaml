<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:dialogs="using:Prosologic.Studio.Views.Dialogs"
        x:Class="Prosologic.Studio.Views.Dialogs.MessageDialog"
        x:DataType="dialogs:MessageDialog"
        Title="{Binding DialogTitle}"
		Width="450" Height="200"
        MinHeight="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1E1E1E"
        SizeToContent="Height">
	
	<DockPanel Margin="20">

		<!-- Content Area -->
		<Grid DockPanel.Dock="Top"
              ColumnDefinitions="Auto,*"
              Margin="0,0,0,20">

			<!-- Icon -->
			<Border Grid.Column="0"
                    Width="48" Height="48"
                    CornerRadius="24"
                    Background="{Binding IconBackground}"
                    Margin="0,0,15,0"
                    VerticalAlignment="Top">
				<TextBlock Text="{Binding Icon}"
                           FontSize="24"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
			</Border>

			<!-- Message -->
			<TextBlock Grid.Column="1"
                       Text="{Binding Message}"
                       Foreground="#CCCCCC"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"
                       FontSize="13"/>

		</Grid>

		<!-- Buttons -->
		<StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">

			<!-- Primary Button -->
			<Button Content="{Binding PrimaryButtonText}"
                    Click="PrimaryButton_Click"
                    IsVisible="{Binding ShowPrimaryButton}"
                    Width="100"
                    Background="#0E639C"
                    Foreground="White"
                    Padding="12,8"/>

			<!-- Secondary Button -->
			<Button Content="{Binding SecondaryButtonText}"
                    Click="SecondaryButton_Click"
                    IsVisible="{Binding ShowSecondaryButton}"
                    Width="100"
                    Padding="12,8"/>

			<!-- Close Button -->
			<Button Content="{Binding CloseButtonText}"
                    Click="CloseButton_Click"
                    IsVisible="{Binding ShowCloseButton}"
                    Width="100"
                    Padding="12,8"/>

		</StackPanel>

	</DockPanel>

</Window>
