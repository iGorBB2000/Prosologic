<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Prosologic.Studio.Views.Dialogs.InputDialog"
        x:DataType="dialogs:InputDialog"
        Title="{Binding DialogTitle}"
        Width="400" Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1E1E1E">

	<DockPanel Margin="20">

		<!-- Prompt -->
		<TextBlock DockPanel.Dock="Top"
                   Text="{Binding Prompt}"
                   Foreground="#CCCCCC"
                   Margin="0,0,0,10"/>

		<!-- Input -->
		<TextBox DockPanel.Dock="Top"
                 Text="{Binding InputValue}"
                 Watermark="{Binding Placeholder}"
                 Margin="0,0,0,20"
                 Name="InputTextBox"/>

		<!-- Buttons -->
		<StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">
			<Button Content="OK"
                    Click="OkButton_Click"
                    Width="100"
                    Background="#0E639C"
                    Foreground="White"
                    Padding="12,8"
                    IsDefault="True"/>
			<Button Content="Cancel"
                    Click="CancelButton_Click"
                    Width="100"
                    Padding="12,8"
                    IsCancel="True"/>
		</StackPanel>

	</DockPanel>
	
</Window>
