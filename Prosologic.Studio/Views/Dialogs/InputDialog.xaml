<ui:FluentWindow x:Class="Prosologic.Studio.Views.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Input"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#2D2D30"
        ExtendsContentIntoTitleBar="True">

    <StackPanel Margin="24,16,24,20">

        <ui:TitleBar Title="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                     Background="#2D2D30"/>

        <!-- Prompt -->
        <TextBlock x:Name="PromptText"
                   Foreground="#CCCCCC"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Margin="0,8,0,10"/>

        <!-- Input box -->
        <ui:TextBox x:Name="InputBox"
                    FontSize="13"
                    KeyDown="InputBox_KeyDown"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <ui:Button Content="OK"
                       Appearance="Primary"
                       Width="80"
                       Margin="0,0,8,0"
                       Click="OK_Click"/>
            <ui:Button Content="Cancel"
                       Width="80"
                       Click="Cancel_Click"/>
        </StackPanel>

    </StackPanel>

</ui:FluentWindow>
