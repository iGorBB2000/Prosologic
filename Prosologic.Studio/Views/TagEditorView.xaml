<UserControl x:Class="Prosologic.Studio.Views.TagEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <DockPanel Background="{StaticResource BgSurfaceBrush}">

        <!-- ── Panel ID strip ──────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgCanvasBrush}"
                BorderBrush="{StaticResource GridLineBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="TAG CONFIG"
                           Style="{StaticResource PanelIdStyle}"/>
                <!-- Unsaved indicator — amber dot -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}}">
                    <Ellipse Width="5" Height="5" Fill="{StaticResource WarningBrush}" Margin="0,0,5,0"/>
                    <TextBlock Text="MODIFIED"
                               FontFamily="{StaticResource LabelFont}"
                               FontSize="{StaticResource FontSizeXxs}"
                               Foreground="{StaticResource WarningBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Empty state ─────────────────────────────── -->
        <TextBlock DockPanel.Dock="Top"
                   Style="{StaticResource EmptyStateStyle}"
                   Text="— select a tag —"
                   Margin="0,100,0,0"
                   Visibility="{Binding IsTagLoaded, Converter={StaticResource InverseBoolToVis}}"/>

        <!-- ── Tag loaded ───────────────────────────────── -->
        <TabControl Background="Transparent" Padding="0" Margin="0"
                    FontFamily="{StaticResource UiFont}"
                    FontSize="{StaticResource FontSizeSm}"
                    Visibility="{Binding IsTagLoaded, Converter={StaticResource BoolToVis}}">

            <TabItem Header="Properties">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>

                        <!-- ── Name / type hero card ────────────── -->
                        <Border Background="{StaticResource BgCanvasBrush}"
                                BorderBrush="{StaticResource GridLineBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,16,20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="TAG NAME"
                                               FontFamily="{StaticResource LabelFont}"
                                               FontSize="{StaticResource FontSizeXxs}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,0,4"/>
                                    <!-- Inline editable name — looks like a large readout -->
                                    <TextBox Style="{StaticResource HeroInputStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <!-- Data type badge -->
                                <Border Grid.Column="1"
                                        Background="{StaticResource AccentDimBrush}"
                                        BorderBrush="{StaticResource AccentBrush}"
                                        BorderThickness="1"
                                        Padding="10,5"
                                        VerticalAlignment="Bottom"
                                        Margin="16,0,0,4">
                                    <TextBlock Text="{Binding DataType}"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="{StaticResource FontSizeSm}"
                                               Foreground="{StaticResource AccentBrush}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ── Register table: IDENTITY block ───── -->
                        <StackPanel Margin="16,14,16,0">
                            <Border Style="{StaticResource BlockHeaderStyle}">
                                <TextBlock Text="IDENTITY" Style="{StaticResource BlockTitleStyle}"/>
                            </Border>
                            <Border Style="{StaticResource RegisterBlockStyle}">
                                <StackPanel>

                                    <!-- Data Type row -->
                                    <Grid Height="34">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Data Type"
                                                   Style="{StaticResource RegisterKeyStyle}"
                                                   Margin="10,0,0,0"/>
                                        <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                        <ComboBox Grid.Column="2"
                                                  Style="{StaticResource DarkComboBoxStyle}"
                                                  ItemsSource="{Binding AvailableDataTypes}"
                                                  SelectedItem="{Binding DataType}"
                                                  BorderThickness="0"
                                                  Margin="8,4,8,4"
                                                  HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <Border Style="{StaticResource HairlineStyle}"/>

                                    <!-- Access Mode row -->
                                    <Grid Height="34">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Access Mode"
                                                   Style="{StaticResource RegisterKeyStyle}"
                                                   Margin="10,0,0,0"/>
                                        <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                        <ComboBox Grid.Column="2"
                                                  Style="{StaticResource DarkComboBoxStyle}"
                                                  ItemsSource="{Binding AvailableAccessModes}"
                                                  SelectedItem="{Binding AccessMode}"
                                                  BorderThickness="0"
                                                  Margin="8,4,8,4"
                                                  HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <Border Style="{StaticResource HairlineStyle}"/>

                                    <!-- Engineering Unit row -->
                                    <Grid Height="34">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Unit"
                                                   Style="{StaticResource RegisterKeyStyle}"
                                                   Margin="10,0,0,0"/>
                                        <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                        <TextBox Grid.Column="2"
                                                 Style="{StaticResource RegisterInputStyle}"
                                                 Text="{Binding EngineeringUnit, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="10,0,10,0"/>
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ── Register table: ACQUISITION block ── -->
                        <StackPanel Margin="16,14,16,0">
                            <Border Style="{StaticResource BlockHeaderStyle}">
                                <TextBlock Text="ACQUISITION" Style="{StaticResource BlockTitleStyle}"/>
                            </Border>
                            <Border Style="{StaticResource RegisterBlockStyle}">
                                <StackPanel>

                                    <!-- Update Strategy row -->
                                    <Grid Height="34">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Update Strategy"
                                                   Style="{StaticResource RegisterKeyStyle}"
                                                   Margin="10,0,0,0"/>
                                        <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                        <ComboBox Grid.Column="2"
                                                  Style="{StaticResource DarkComboBoxStyle}"
                                                  ItemsSource="{Binding AvailableUpdateStrategies}"
                                                  SelectedItem="{Binding UpdateStrategy}"
                                                  BorderThickness="0"
                                                  Margin="8,4,8,4"
                                                  HorizontalAlignment="Stretch"/>
                                    </Grid>
                                    <Border Style="{StaticResource HairlineStyle}"/>

                                    <!-- Interval row -->
                                    <Grid Height="34">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Interval"
                                                   Style="{StaticResource RegisterKeyStyle}"
                                                   Margin="10,0,0,0"/>
                                        <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                        <TextBox Grid.Column="2"
                                                 Style="{StaticResource RegisterInputStyle}"
                                                 Text="{Binding UpdateInterval, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="10,0,4,0"/>
                                        <TextBlock Grid.Column="3" Text="ms"
                                                   FontFamily="{StaticResource LabelFont}"
                                                   FontSize="{StaticResource FontSizeXs}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,0,10,0"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Border Style="{StaticResource HairlineStyle}"/>

                                    <!-- Initial Value row -->
                                    <Grid Height="34">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="1"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Initial Value"
                                                   Style="{StaticResource RegisterKeyStyle}"
                                                   Margin="10,0,0,0"/>
                                        <Border Grid.Column="1" Background="{StaticResource GridLineBrush}"/>
                                        <TextBox Grid.Column="2"
                                                 Style="{StaticResource RegisterInputStyle}"
                                                 Text="{Binding InitialValue, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="10,0,10,0"/>
                                    </Grid>

                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- ── Description block ────────────────── -->
                        <StackPanel Margin="16,14,16,0">
                            <Border Style="{StaticResource BlockHeaderStyle}">
                                <TextBlock Text="NOTES" Style="{StaticResource BlockTitleStyle}"/>
                            </Border>
                            <Border Style="{StaticResource RegisterBlockStyle}">
                                <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         Height="72" BorderThickness="0"/>
                            </Border>
                        </StackPanel>

                        <!-- Script notice -->
                        <Border Margin="16,10,16,0"
                                Background="{StaticResource AccentTintBrush}"
                                BorderBrush="{StaticResource AccentDimBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="10,7"
                                Visibility="{Binding IsScriptRequired, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="▶  Script-driven tag — use the Script tab to edit logic"
                                       FontFamily="{StaticResource LabelFont}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource AccentBrush}"/>
                        </Border>

                        <!-- ── Action bar ────────────────────────── -->
                        <Border Margin="16,14,16,20"
                                Background="{StaticResource BgCanvasBrush}"
                                BorderBrush="{StaticResource GridLineBrush}"
                                BorderThickness="1"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:Button Grid.Column="0" Content="SAVE"
                                           Command="{Binding SaveCommand}" Appearance="Primary"/>
                                <ui:Button Grid.Column="2" Content="RESET"
                                           Command="{Binding ResetCommand}"/>
                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                                            Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}}">
                                    <Ellipse Width="4" Height="4"
                                             Fill="{StaticResource WarningBrush}" Margin="0,0,5,0"/>
                                    <TextBlock Text="unsaved changes"
                                               FontFamily="{StaticResource LabelFont}"
                                               FontSize="{StaticResource FontSizeXs}"
                                               Foreground="{StaticResource WarningBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── Script tab ──────────────────────────── -->
            <TabItem Header="Script" IsEnabled="{Binding IsScriptRequired}">
                <DockPanel Background="{StaticResource BgInsetBrush}">
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource BgCanvasBrush}"
                            BorderBrush="{StaticResource GridLineBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="C#"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="{StaticResource FontSizeSm}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource LiveBrush}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Return the computed tag value. Use 'value' for the current reading."
                                       FontFamily="{StaticResource UiFont}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource TextLabelBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border DockPanel.Dock="Bottom"
                            Background="{StaticResource BgCanvasBrush}"
                            BorderBrush="{StaticResource GridLineBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="12,7">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="SAVE" Command="{Binding SaveCommand}"
                                       Appearance="Primary" Margin="0,0,8,0"/>
                            <ui:Button Content="RESET" Command="{Binding ResetCommand}" Margin="0,0,14,0"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}}">
                                <Ellipse Width="4" Height="4"
                                         Fill="{StaticResource WarningBrush}" Margin="0,0,5,0"/>
                                <TextBlock Text="unsaved"
                                           FontFamily="{StaticResource LabelFont}"
                                           FontSize="{StaticResource FontSizeXs}"
                                           Foreground="{StaticResource WarningBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <TextBox Text="{Binding ScriptContent, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="12.5"
                             TextWrapping="NoWrap"
                             Background="{StaticResource BgInsetBrush}"
                             Foreground="#AAB4C8"
                             CaretBrush="{StaticResource AccentBrush}"
                             SelectionBrush="{StaticResource AccentDimBrush}"
                             Padding="18" BorderThickness="0"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
