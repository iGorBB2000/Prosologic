<UserControl x:Class="Prosologic.Studio.Views.TagGroupEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:Prosologic.Studio.ViewModels">

    <DockPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="#2D2D30"
                Padding="12,8"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,0,1">
            <TextBlock Text="TAG GROUP PROPERTIES"
                       Foreground="#CCCCCC"
                       FontWeight="SemiBold"
                       FontSize="12"/>
        </Border>

        <!-- Content -->
        <ScrollViewer>
            <StackPanel Margin="20">

                <!-- Not loaded -->
                <TextBlock Text="Select a tag group to edit its properties"
                           Foreground="#808080"
                           FontStyle="Italic"
                           Margin="0,0,0,12"
                           Visibility="{Binding IsGroupLoaded, Converter={StaticResource InverseBoolToVis}}"/>

                <!-- Loaded -->
                <StackPanel Visibility="{Binding IsGroupLoaded, Converter={StaticResource BoolToVis}}">
                    <StackPanel.Resources>
                        <Style TargetType="StackPanel">
                            <Setter Property="Margin" Value="0,0,0,12"/>
                        </Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CCCCCC"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                        </Style>
                    </StackPanel.Resources>

                    <!-- Name -->
                    <StackPanel>
                        <TextBlock Text="Name"/>
                        <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Tag group name"/>
                    </StackPanel>

                    <!-- Description -->
                    <StackPanel>
                        <TextBlock Text="Description"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="100"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Content="Save Changes"
                                   Command="{Binding SaveCommand}"
                                   Appearance="Primary"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Reset"
                                   Command="{Binding ResetCommand}"/>
                    </StackPanel>

                    <!-- Unsaved indicator -->
                    <TextBlock Text="● Unsaved changes"
                               Foreground="#FFA500"
                               FontSize="11"
                               Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}}"/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>
