<UserControl x:Class="Prosologic.Studio.Views.TagGroupEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <DockPanel Background="{StaticResource BgSurfaceBrush}">

        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgCanvasBrush}"
                BorderBrush="{StaticResource GridLineBrush}"
                BorderThickness="0,0,0,1" Padding="16,6">
            <TextBlock Text="TAG GROUP" Style="{StaticResource PanelIdStyle}"/>
        </Border>

        <TextBlock DockPanel.Dock="Top"
                   Style="{StaticResource EmptyStateStyle}"
                   Text="— select a tag group —"
                   Margin="0,80,0,0"
                   Visibility="{Binding IsGroupLoaded, Converter={StaticResource InverseBoolToVis}}"/>

        <ScrollViewer Visibility="{Binding IsGroupLoaded, Converter={StaticResource BoolToVis}}">
            <StackPanel>

                <!-- Name hero -->
                <Border Background="{StaticResource BgCanvasBrush}"
                        BorderBrush="{StaticResource GridLineBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="GROUP NAME"
                                   FontFamily="{StaticResource LabelFont}"
                                   FontSize="{StaticResource FontSizeXxs}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource HeroInputStyle}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Description block -->
                <StackPanel Margin="16,14,16,0">
                    <Border Style="{StaticResource BlockHeaderStyle}">
                        <TextBlock Text="NOTES" Style="{StaticResource BlockTitleStyle}"/>
                    </Border>
                    <Border Style="{StaticResource RegisterBlockStyle}">
                        <TextBox Style="{StaticResource DarkTextBoxStyle}"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="100" BorderThickness="0"/>
                    </Border>
                </StackPanel>

                <!-- Action bar -->
                <Border Margin="16,14,16,20"
                        Background="{StaticResource BgCanvasBrush}"
                        BorderBrush="{StaticResource GridLineBrush}"
                        BorderThickness="1" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0" Content="SAVE"
                                   Command="{Binding SaveCommand}" Appearance="Primary"/>
                        <ui:Button Grid.Column="2" Content="RESET"
                                   Command="{Binding ResetCommand}"/>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="4" Height="4"
                                     Fill="{StaticResource WarningBrush}" Margin="0,0,5,0"/>
                            <TextBlock Text="unsaved changes"
                                       FontFamily="{StaticResource LabelFont}"
                                       FontSize="{StaticResource FontSizeXs}"
                                       Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
