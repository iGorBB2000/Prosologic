<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        PROSOLOGIC STUDIO — INSTRUMENT PANEL DESIGN SYSTEM v4
        ───────────────────────────────────────────────────────
        Changes from v3:
        • Lighter navy base (~#141828 range) — less oppressive
        • Higher text contrast — labels at #9AA0BC, values at #E8EBF5
        • Amber accent kept, extended to ALL focus/selection states
        • Register table: field bg matches border exactly — no gap
        • ComboBox + TextBox: dark bg, light foreground, amber focus
        • Explorer selection: full-width stripe, left accent bar
        • Status bar: legible text on deep bg
    -->

    <!-- ── Surfaces (deep cold blue) ───────────────────── -->
    <SolidColorBrush x:Key="BgCanvasBrush"   Color="#080D14"/>
    <SolidColorBrush x:Key="BgPanelBrush"    Color="#0D1520"/>
    <SolidColorBrush x:Key="BgSurfaceBrush"  Color="#111C28"/>
    <SolidColorBrush x:Key="BgRaisedBrush"   Color="#162030"/>
    <SolidColorBrush x:Key="BgInsetBrush"    Color="#050A10"/>
    <SolidColorBrush x:Key="BgHoverBrush"    Color="#1A2638"/>
    <SolidColorBrush x:Key="BgSelectedBrush" Color="#1E2C40"/>

    <!-- ── Borders ─────────────────────────────────────── -->
    <SolidColorBrush x:Key="GridLineBrush"      Color="#162030"/>
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="#1E2C3E"/>
    <SolidColorBrush x:Key="BorderActiveBrush"  Color="#2E4460"/>

    <!-- ── Text ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TextPrimaryBrush"  Color="#DCE8F5"/>
    <SolidColorBrush x:Key="TextLabelBrush"    Color="#6880A0"/>
    <SolidColorBrush x:Key="TextMutedBrush"    Color="#304058"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="#1A2434"/>

    <!-- ── Accent ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="AccentBrush"       Color="#E8A020"/>
    <SolidColorBrush x:Key="AccentHoverBrush"  Color="#F0B040"/>
    <SolidColorBrush x:Key="AccentTintBrush"   Color="#201600"/>
    <SolidColorBrush x:Key="AccentDimBrush"    Color="#3A2800"/>

    <!-- ── Semantic ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="WarningBrush"  Color="#E8A020"/>
    <SolidColorBrush x:Key="LiveBrush"     Color="#26C99E"/>
    <SolidColorBrush x:Key="DangerBrush"   Color="#C84040"/>
    <SolidColorBrush x:Key="MqttBrush"     Color="#26C99E"/>
    <SolidColorBrush x:Key="OpcUaBrush"    Color="#8080E0"/>

    <!-- ── Typography ────────────────────────────────────── -->
    <FontFamily x:Key="UiFont">Segoe UI Variable Display, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="LabelFont">Segoe UI Variable Small, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, JetBrains Mono, Consolas, monospace</FontFamily>

    <sys:Double x:Key="FontSizeXxs">9</sys:Double>
    <sys:Double x:Key="FontSizeXs">10.5</sys:Double>
    <sys:Double x:Key="FontSizeSm">12</sys:Double>
    <sys:Double x:Key="FontSizeMd">13</sys:Double>
    <sys:Double x:Key="FontSizeLg">16</sys:Double>
    <sys:Double x:Key="FontSizeXl">22</sys:Double>

    <!-- ════════════════════════════════════════════════════
         TEXT STYLES
    ════════════════════════════════════════════════════ -->

    <Style x:Key="PanelIdStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource LabelFont}"/>
        <Setter Property="FontSize"    Value="{StaticResource FontSizeXxs}"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="{StaticResource TextMutedBrush}"/>
    </Style>

    <Style x:Key="RegisterKeyStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"        Value="{StaticResource LabelFont}"/>
        <Setter Property="FontSize"          Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Foreground"        Value="{StaticResource TextLabelBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="BlockTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource LabelFont}"/>
        <Setter Property="FontSize"    Value="{StaticResource FontSizeXxs}"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="{StaticResource AccentBrush}"/>
    </Style>

    <Style x:Key="EmptyStateStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"          Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"            Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Foreground"          Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
    </Style>

    <!-- ════════════════════════════════════════════════════
         LAYOUT STYLES
    ════════════════════════════════════════════════════ -->

    <Style x:Key="HairlineStyle" TargetType="Border">
        <Setter Property="Height"     Value="1"/>
        <Setter Property="Background" Value="{StaticResource GridLineBrush}"/>
    </Style>

    <!-- Block header: same bg as the table border colour so the
         top corners look continuous, no colour gap -->
    <Style x:Key="BlockHeaderStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource BgRaisedBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource GridLineBrush}"/>
        <Setter Property="BorderThickness" Value="1,1,1,0"/>
        <Setter Property="Padding"         Value="10,5"/>
    </Style>

    <!-- Register block: MUST share BorderBrush with BlockHeaderStyle -->
    <Style x:Key="RegisterBlockStyle" TargetType="Border">
        <!-- Field rows sit directly on BgPanelBrush — same as
             what shows through the border, so no colour gap -->
        <Setter Property="Background"      Value="{StaticResource BgPanelBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource GridLineBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="HintBannerStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource AccentTintBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource AccentDimBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding"         Value="10,7"/>
    </Style>

    <Style x:Key="SplitterStyle" TargetType="GridSplitter">
        <Setter Property="Background"          Value="{StaticResource GridLineBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment"   Value="Stretch"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════════════════
         INPUT CONTROLS — amber focus everywhere
    ════════════════════════════════════════════════════ -->

    <!-- Single-line register row input — flush, no box, bottom border only on focus -->
    <Style x:Key="RegisterInputStyle" TargetType="TextBox">
        <Setter Property="FontFamily"      Value="{DynamicResource MonoFont}"/>
        <Setter Property="FontSize"        Value="{DynamicResource FontSizeSm}"/>
        <Setter Property="Background"      Value="{DynamicResource BgPanelBrush}"/>
        <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush"      Value="{DynamicResource AccentBrush}"/>
        <Setter Property="SelectionBrush"  Value="{DynamicResource AccentDimBrush}"/>
        <Setter Property="BorderBrush"     Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding"         Value="0,5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Multi-line TextBox -->
    <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily"      Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Background"      Value="{StaticResource BgPanelBrush}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush"      Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush"  Value="{StaticResource AccentDimBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource GridLineBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Padding"         Value="10,7"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!-- Large hero TextBox (tag name, project name, group name).
         Plain WPF TextBox with custom template — avoids WPF-UI's
         hardcoded blue focus chrome entirely. Amber on focus. -->
    <Style x:Key="HeroInputStyle" TargetType="TextBox">
        <Setter Property="FontFamily"      Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeXl}"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="CaretBrush"      Value="{StaticResource AccentBrush}"/>
        <Setter Property="SelectionBrush"  Value="{StaticResource AccentDimBrush}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource GridLineBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding"         Value="0,0,0,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox — full-width clickable, chevron layered separately -->
    <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FontFamily"                 Value="{DynamicResource MonoFont}"/>
        <Setter Property="FontSize"                   Value="{DynamicResource FontSizeSm}"/>
        <Setter Property="Foreground"                 Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="Background"                 Value="{DynamicResource BgPanelBrush}"/>
        <Setter Property="BorderBrush"                Value="Transparent"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="FontFamily"  Value="{DynamicResource MonoFont}"/>
                    <Setter Property="FontSize"    Value="{DynamicResource FontSizeSm}"/>
                    <Setter Property="Foreground"  Value="{DynamicResource TextPrimaryBrush}"/>
                    <Setter Property="Background"  Value="{DynamicResource BgRaisedBrush}"/>
                    <Setter Property="Padding"     Value="10,6"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource BgHoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid x:Name="Root">
                        <!--
                            Layer 1 (bottom): ToggleButton covers the ENTIRE control area.
                            It has no content of its own — just a transparent-background
                            clickable region so anywhere in the field opens the dropdown.
                        -->
                        <ToggleButton x:Name="ToggleButton"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="{DynamicResource BgPanelBrush}"
                                      BorderThickness="0"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                          RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <!-- Plain full-area background — no content, no columns -->
                                    <Border x:Name="Bg"
                                            Background="{DynamicResource BgPanelBrush}"
                                            BorderThickness="0"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background"
                                                    Value="{DynamicResource BgHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!--
                            Layer 2: Selected value text, left-aligned with right padding
                            for the chevron. IsHitTestVisible=False so clicks pass through
                            to the ToggleButton below.
                        -->
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="10,0,28,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>

                        <!--
                            Layer 3: Chevron arrow, right-aligned, non-interactive.
                            Fixed 20px width, centred vertically.
                        -->
                        <Path x:Name="Arrow"
                              Data="M 3,4 L 8,9 L 13,4"
                              Stroke="{DynamicResource TextLabelBrush}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="16" Height="10"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,6,0"
                              IsHitTestVisible="False"/>

                        <!-- Dropdown popup -->
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    Background="{DynamicResource BgRaisedBrush}"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="200">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Arrow" Property="Stroke"
                                    Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════
         TREE VIEW — full-width selection with left amber bar
    ════════════════════════════════════════════════════ -->

    <Style x:Key="ChevronToggleStyle" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Width"     Value="14"/>
        <Setter Property="Height"    Value="14"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent">
                        <Path x:Name="Arrow"
                              Data="M 4,2 L 10,7 L 4,12"
                              Stroke="{DynamicResource TextMutedBrush}"
                              StrokeThickness="1.5"
                              StrokeLineJoin="Round"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Arrow" Property="Data"  Value="M 2,4 L 7,10 L 12,4"/>
                            <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource TextLabelBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ExplorerTreeItemStyle" TargetType="TreeViewItem">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Foreground"                 Value="{DynamicResource TextLabelBrush}"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="IsExpanded"  Value="{Binding IsExpanded, Mode=TwoWay}"/>
        <Setter Property="IsSelected"  Value="{Binding IsSelected, Mode=TwoWay}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- Full-width row with amber left bar when selected -->
                        <Grid x:Name="RowGrid" Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <!-- Amber selection bar -->
                                <ColumnDefinition Width="2"/>
                                <!-- Indent + content -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left accent bar — only visible when selected -->
                            <Border x:Name="AccentBar"
                                    Grid.Column="0"
                                    Background="Transparent"/>

                            <!-- Row background -->
                            <Border x:Name="Bd"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    Padding="4,5,8,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  Style="{DynamicResource ChevronToggleStyle}"
                                                  IsChecked="{Binding IsExpanded,
                                                      RelativeSource={RelativeSource TemplatedParent},
                                                      Mode=TwoWay}"
                                                  ClickMode="Press"/>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="16,0,0,0"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <!-- Selected: amber bar + tinted bg + amber text -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="AccentBar" Property="Background"
                                    Value="{DynamicResource AccentBrush}"/>
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource BgSelectedBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <!-- Hover: subtle bg, no bar -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected"  Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <MultiTrigger.Setters>
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource BgHoverBrush}"/>
                            </MultiTrigger.Setters>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
